{
  "private": true,
  "type": "module",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.1.0",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.0.16",
    "vite-plugin-ruby": "^5.2.2"
  },
  "scripts": {
    "check": "tsc -p tsconfig.app.json && tsc -p tsconfig.node.json",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint app/javascript",
    "lint:fix": "eslint app/javascript --fix",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.rb": "bin/rubocop --force-exclusion",
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,css,json}": "prettier --write"
  },
  "dependencies": {
    "@inertiajs/react": "^3.4.0",
    "@inertiajs/vite": "^3.4.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.1"
  }
}
